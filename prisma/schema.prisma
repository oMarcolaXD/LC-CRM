generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COLLABORATOR
  TEACHER
  STUDENT
  GUARDIAN
}

enum LessonStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  MISSED
}

enum LessonModality {
  PRESENCIAL
  ONLINE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum PackageStatus {
  ACTIVE
  EXPIRED
  EXHAUSTED
}

enum HomeworkStatus {
  PENDING
  COMPLETED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum TeacherMode {
  ONLINE_ONLY  // só online, de casa
  PRESENCIAL   // vem à sede; dá presencial E pode dar online ocupando uma sala
  HYBRID       // pode trabalhar de casa (online) E vir à sede (presencial/online)
}

enum EducationLevel {
  EF2        // Fundamental 2 (6º–9º ano)
  EM         // Ensino Médio
  SUPERIOR   // Ensino Superior
  VESTIBULAR // Preparatório vestibular
}

// ─── Usuário Base ─────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  name            String
  email           String?  @unique
  password        String
  phone           String?  @unique
  role            Role     @default(STUDENT)
  avatar          String?
  active          Boolean  @default(true)
  lastSeenVersion String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student       Student?
  guardian      Guardian?
  teacher       Teacher?
  notifications Notification[]
  activityLogs  ActivityLog[]

  @@map("users")
}

// ─── Perfis ───────────────────────────────────────────────────────────────────

model Student {
  id         String    @id @default(cuid())
  userId     String?   @unique
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  grade          String
  educationLevel EducationLevel?
  school         String?
  guardianId     String?
  guardian   Guardian? @relation(fields: [guardianId], references: [id])
  notes      String?

  packages       LessonPackage[]
  participations LessonParticipant[]
  requests       LessonRequest[]
  payments       Payment[]

  @@map("students")
}

model Guardian {
  id           String  @id @default(cuid())
  userId       String  @unique
  relationship String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  students Student[]

  @@map("guardians")
}

model Teacher {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hourlyRate   Decimal      @db.Decimal(10, 2)
  bio          String?
  availability Json?
  teachingMode TeacherMode  @default(HYBRID)

  subjects  TeacherSubject[]
  lessons   Lesson[]
  requests  LessonRequest[]
  materials Material[]
  payouts   TeacherPayout[]

  @@map("teachers")
}

// ─── Matérias ─────────────────────────────────────────────────────────────────

model Subject {
  id    String  @id @default(cuid())
  name  String
  level String?

  teacherSubjects TeacherSubject[]
  lessons         Lesson[]
  materials       Material[]
  lessonRequests  LessonRequest[]

  @@map("subjects")
}

model TeacherSubject {
  teacherId String
  subjectId String
  levels    EducationLevel[]
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([teacherId, subjectId])
  @@map("teacher_subjects")
}

// ─── Pacotes de Aulas ─────────────────────────────────────────────────────────

model LessonPackage {
  id               String        @id @default(cuid())
  studentId        String
  student          Student       @relation(fields: [studentId], references: [id])
  totalLessons     Int
  remainingLessons Int
  pricePerLesson   Decimal       @db.Decimal(10, 2)
  purchaseDate     DateTime      @default(now())
  expiresAt        DateTime?
  status           PackageStatus @default(ACTIVE)

  @@map("lesson_packages")
}

// ─── Aulas ────────────────────────────────────────────────────────────────────

model Lesson {
  id              String         @id @default(cuid())
  teacherId       String
  teacher         Teacher        @relation(fields: [teacherId], references: [id])
  subjectId       String
  subject         Subject        @relation(fields: [subjectId], references: [id])
  scheduledAt     DateTime
  duration        Int            @default(60)
  modality        LessonModality @default(PRESENCIAL)
  location        String?
  meetingLink     String?
  status          LessonStatus   @default(SCHEDULED)
  topicsCovered   String?
  teacherNotes    String?
  studentRating   Int?
  studentFeedback String?
  priceOverride   Decimal?       @db.Decimal(10, 2)
  teacherOnsite   Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  participants LessonParticipant[]
  homework     Homework[]

  @@index([teacherId])
  @@index([status])
  @@index([scheduledAt])
  @@index([teacherId, status, scheduledAt])
  @@map("lessons")
}

model LessonParticipant {
  lessonId  String
  studentId String
  lesson    Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([lessonId, studentId])
  @@index([studentId])
  @@map("lesson_participants")
}

model LessonRequest {
  id          String        @id @default(cuid())
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id])
  teacherId   String
  teacher     Teacher       @relation(fields: [teacherId], references: [id])
  requestedAt DateTime      @default(now())
  preferredAt DateTime
  subjectId   String?
  subject     Subject?      @relation(fields: [subjectId], references: [id])
  modality       LessonModality @default(PRESENCIAL)
  status         RequestStatus  @default(PENDING)
  approvedBy     String?
  reason         String?
  isGroupRequest Boolean        @default(false)
  groupNote      String?

  @@index([teacherId, status])
  @@index([studentId, status])
  @@map("lesson_requests")
}

// ─── Lição de Casa ────────────────────────────────────────────────────────────

model Homework {
  id          String         @id @default(cuid())
  lessonId    String
  lesson      Lesson         @relation(fields: [lessonId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  attachments String[]
  status      HomeworkStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime       @default(now())

  @@map("homework")
}

// ─── Material Didático ────────────────────────────────────────────────────────

model Material {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  studentId  String?
  subjectId  String?
  subject    Subject? @relation(fields: [subjectId], references: [id])
  title      String
  fileUrl    String
  fileType   String
  uploadedAt DateTime @default(now())

  @@map("materials")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        PaymentStatus @default(PENDING)
  method        String?
  mercadoPagoId String?
  description   String?
  createdAt     DateTime      @default(now())

  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

model TeacherPayout {
  id           String       @id @default(cuid())
  teacherId    String
  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  month        Int
  year         Int
  totalLessons Int
  totalAmount  Decimal      @db.Decimal(10, 2)
  paidAt       DateTime?
  status       PayoutStatus @default(PENDING)

  @@map("teacher_payouts")
}

// ─── Configurações do Sistema ─────────────────────────────────────────────────

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// ─── Notificações e Auditoria ─────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}
