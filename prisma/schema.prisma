generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COLLABORATOR
  TEACHER
  STUDENT
  GUARDIAN
}

enum LessonStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  MISSED
}

enum LessonModality {
  PRESENCIAL
  ONLINE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum PackageStatus {
  ACTIVE
  EXPIRED
  EXHAUSTED
}

enum HomeworkStatus {
  PENDING
  COMPLETED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum TeacherMode {
  ONLINE_ONLY  // só online, de casa
  PRESENCIAL   // vem à sede; dá presencial E pode dar online ocupando uma sala
  HYBRID       // pode trabalhar de casa (online) E vir à sede (presencial/online)
}

enum RoomType {
  PHYSICAL
  VIRTUAL
}

enum LessonType {
  INDIVIDUAL
  GROUP
  AULAO
  COMPROMISSO
}

enum EducationLevel {
  EF2        // Fundamental 2 (6º–9º ano)
  EM         // Ensino Médio
  SUPERIOR   // Ensino Superior
  VESTIBULAR // Preparatório vestibular
}

// ─── Usuário Base ─────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  name            String
  email           String?  @unique
  password        String
  phone           String?
  role            Role     @default(STUDENT)
  avatar          String?
  active          Boolean  @default(true)
  lastSeenVersion String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student        Student?
  guardian       Guardian?
  teacher        Teacher?
  notifications  Notification[]
  activityLogs   ActivityLog[]
  authoredNotes  StudentNote[]
  cancellationRequests LessonCancellationRequest[] @relation("CancellationRequests")
  cancellationReviews  LessonCancellationRequest[] @relation("CancellationReviews")
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

// ─── Recuperação de senha ───────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Perfis ───────────────────────────────────────────────────────────────────

model Student {
  id         String    @id @default(cuid())
  userId     String?   @unique
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  grade          String
  educationLevel EducationLevel?
  school         String?
  guardianId     String?
  guardian   Guardian? @relation(fields: [guardianId], references: [id])
  notes      String?
  tags       String[]
  createdAt  DateTime  @default(now())

  packages       LessonPackage[]
  participations LessonParticipant[]
  requests       LessonRequest[]
  payments       Payment[]
  studentNotes   StudentNote[]
  materials      MaterialStudent[]

  @@map("students")
}

model Guardian {
  id           String  @id @default(cuid())
  userId       String  @unique
  relationship String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  students Student[]

  @@map("guardians")
}

model StudentNote {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([studentId])
  @@map("student_notes")
}

model Teacher {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hourlyRate   Decimal      @db.Decimal(10, 2)
  bio          String?
  availability Json?
  teachingMode TeacherMode  @default(HYBRID)

  subjects  TeacherSubject[]
  lessons   Lesson[]
  requests  LessonRequest[]
  materials Material[]
  payouts   TeacherPayout[]

  @@map("teachers")
}

// ─── Salas ────────────────────────────────────────────────────────────────────

model Room {
  id       String   @id @default(cuid())
  name     String
  capacity Int?
  type     RoomType @default(PHYSICAL)
  active   Boolean  @default(true)

  lessons  Lesson[]

  @@map("rooms")
}

// ─── Recorrência ──────────────────────────────────────────────────────────────

model RecurrenceGroup {
  id        String    @id @default(cuid())
  rule      String
  startsAt  DateTime
  endsAt    DateTime?
  createdAt DateTime  @default(now())

  lessons   Lesson[]

  @@map("recurrence_groups")
}

// ─── Matérias ─────────────────────────────────────────────────────────────────

model Subject {
  id    String  @id @default(cuid())
  name  String
  level String?

  teacherSubjects TeacherSubject[]
  lessons         Lesson[]
  materials       Material[]
  lessonRequests  LessonRequest[]

  @@map("subjects")
}

model TeacherSubject {
  teacherId String
  subjectId String
  levels    EducationLevel[]
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([teacherId, subjectId])
  @@map("teacher_subjects")
}

// ─── Pacotes de Aulas ─────────────────────────────────────────────────────────

model LessonPackage {
  id               String        @id @default(cuid())
  studentId        String
  student          Student       @relation(fields: [studentId], references: [id])
  totalLessons     Decimal       @db.Decimal(5, 1)
  remainingLessons Decimal       @db.Decimal(5, 1)
  pricePerLesson   Decimal       @db.Decimal(10, 2)
  purchaseDate     DateTime      @default(now())
  expiresAt        DateTime?
  status           PackageStatus @default(ACTIVE)

  @@map("lesson_packages")
}

// ─── Aulas ────────────────────────────────────────────────────────────────────

model Lesson {
  id              String         @id @default(cuid())
  teacherId       String
  teacher         Teacher        @relation(fields: [teacherId], references: [id])
  subjectId       String?
  subject         Subject?       @relation(fields: [subjectId], references: [id])
  scheduledAt     DateTime
  duration        Int            @default(60)
  modality        LessonModality @default(PRESENCIAL)
  location        String?
  meetingLink     String?
  status          LessonStatus   @default(SCHEDULED)
  lessonType      LessonType     @default(INDIVIDUAL)
  title           String?
  capacity        Int?
  topicsCovered   String?
  teacherNotes    String?
  studentRating   Int?
  studentFeedback String?
  priceOverride     Decimal?       @db.Decimal(10, 2)
  teacherOnsite     Boolean        @default(false)
  roomId            String?
  room              Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  recurrenceGroupId String?
  recurrenceGroup   RecurrenceGroup? @relation(fields: [recurrenceGroupId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  participants         LessonParticipant[]
  homework             Homework[]
  cancellationRequests LessonCancellationRequest[]

  @@index([teacherId])
  @@index([status])
  @@index([scheduledAt])
  @@index([teacherId, status, scheduledAt])
  @@map("lessons")
}

model LessonParticipant {
  lessonId  String
  studentId String
  lesson    Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([lessonId, studentId])
  @@index([studentId])
  @@map("lesson_participants")
}

model LessonRequest {
  id          String        @id @default(cuid())
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id])
  teacherId   String
  teacher     Teacher       @relation(fields: [teacherId], references: [id])
  requestedAt DateTime      @default(now())
  preferredAt DateTime
  subjectId   String?
  subject     Subject?      @relation(fields: [subjectId], references: [id])
  modality       LessonModality @default(PRESENCIAL)
  status         RequestStatus  @default(PENDING)
  approvedBy     String?
  reason         String?
  isGroupRequest Boolean        @default(false)
  groupNote      String?

  @@index([teacherId, status])
  @@index([studentId, status])
  @@map("lesson_requests")
}

model LessonCancellationRequest {
  id            String        @id @default(cuid())
  lessonId      String
  lesson        Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User          @relation("CancellationRequests", fields: [requestedById], references: [id])
  reason        String?
  status        RequestStatus @default(PENDING)
  reviewedById  String?
  reviewedBy    User?         @relation("CancellationReviews", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([lessonId])
  @@index([requestedById])
  @@index([status])
  @@map("lesson_cancellation_requests")
}

// ─── Lição de Casa ────────────────────────────────────────────────────────────

model Homework {
  id          String         @id @default(cuid())
  lessonId    String
  lesson      Lesson         @relation(fields: [lessonId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  attachments String[]
  status      HomeworkStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime       @default(now())

  @@map("homework")
}

// ─── Material Didático ────────────────────────────────────────────────────────

model Material {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  subjectId  String?
  subject    Subject? @relation(fields: [subjectId], references: [id])
  title      String
  fileUrl    String
  fileType   String
  uploadedAt DateTime @default(now())

  students   MaterialStudent[]

  @@map("materials")
}

model MaterialStudent {
  materialId String
  studentId  String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([materialId, studentId])
  @@index([studentId])
  @@map("material_students")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        PaymentStatus @default(PENDING)
  method        String?
  mercadoPagoId String?
  description   String?
  createdAt     DateTime      @default(now())

  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

model TeacherPayout {
  id           String       @id @default(cuid())
  teacherId    String
  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  month        Int
  year         Int
  totalLessons Decimal      @db.Decimal(5, 1)
  totalAmount  Decimal      @db.Decimal(10, 2)
  paidAt       DateTime?
  status       PayoutStatus @default(PENDING)

  @@unique([teacherId, month, year])
  @@map("teacher_payouts")
}

// ─── Metas Mensais ────────────────────────────────────────────────────────────

model MonthlyGoal {
  id           String   @id @default(cuid())
  year         Int
  month        Int      // 1–12
  revenueGoal  Decimal? @db.Decimal(10, 2)
  lessonsGoal  Int?
  studentsGoal Int?
  updatedAt    DateTime @updatedAt

  @@unique([year, month])
  @@map("monthly_goals")
}

// ─── Configurações do Sistema ─────────────────────────────────────────────────

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// ─── Notificações e Auditoria ─────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}
